generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String @id @default(cuid())
  email String @unique
}

model NonPlayableCharacter {
  id    Int    @id @default(autoincrement())
  name  String
  desc  String?
  userId String
  audio Audio?
}

model Audio {
  id     String @id
  key    String
  status String @default("processing")
  npcId  Int @unique
  npc    NonPlayableCharacter @relation(fields: [npcId], references: [id])
}
